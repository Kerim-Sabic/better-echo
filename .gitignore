# Electron Desktop
dist/
out/
*.log
backend/dist/
backend/desktop/build/
backend/desktop/*.exe
backend/desktop/*.app
backend/desktop/generated_release_config.py
backend/desktop/generated_runtime.env
dist/electron/
backend/dist/api/
