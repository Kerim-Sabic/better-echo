CORS_ORIGIN=["http://localhost:3000"] #frontend

ORTHANC_URL="http://localhost:8042"
ORTHANC_USER="orthanc"
ORTHANC_PASS="orthanc"

SECRET_KEY=supersecretkey12345
TOKEN_EXPIRE_HOURS=4
# Model preload toggles (default on; set to false on low-VRAM machines)
PANECHO_PRELOAD=true
PANECHO_WARMUP=false
ECHOPRIME_PRELOAD=true
ECHOPRIME_WARMUP=false
ECHONET_PRELOAD=true
ECHONET_WARMUP=false
MEASUREMENTS_PRELOAD=true
MEASUREMENTS_WARMUP=false

# Batch sizes (conservative defaults; lower on low-VRAM machines)
PANECHO_BATCH=8
ECHONET_BATCH=16
MEASUREMENTS_BATCH=16
MEASUREMENTS_OUTPUT_FPS=30

# Preferred devices (auto | cpu | cuda:<index>)
PANECHO_DEVICE=auto
ECHO_PRIME_DEVICE=auto
ECHONET_DEVICE=auto
MEASUREMENTS_DEVICE=auto
