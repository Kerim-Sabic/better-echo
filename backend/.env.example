# Frontend origin allowlist used by backend CORS middleware.
# Use JSON array syntax or a comma-separated list without inline trailing comments.
CORS_ORIGIN=["http://localhost:3000"]

# Orthanc server connection (URL + Basic Auth credentials).
ORTHANC_URL="http://localhost:8042"
ORTHANC_USER="orthanc"
ORTHANC_PASS="orthanc"

# Packaged server backend bind contract.
BACKEND_HOST="0.0.0.0"
BACKEND_PORT=8000

# Local packaged-server Docker infra ports/base URLs.
POSTGRES_PORT=5433
VIEWER_PUBLIC_BASE_URL="http://localhost:3001"
STOP_LOCAL_INFRA_ON_QUIT=true

# Backend database connection URL.
# Canonical local/dev PostgreSQL example:
# - postgresql+psycopg://horalix:horalix_dev@localhost:5433/horalix
DATABASE_URL="postgresql+psycopg://horalix:horalix_dev@localhost:5433/horalix"

# Dedicated database for backend tests.
# The backend test harness clears all tables in this database on each run.
TEST_DATABASE_URL="postgresql+psycopg://horalix:horalix_dev@localhost:5433/horalix_test"

# JWT signing secret for authentication cookies.
SECRET_KEY=supersecretkey12345

# Login token lifetime in hours.
TOKEN_EXPIRE_HOURS=4

# Mark the auth cookie as Secure (browsers refuse to send it over plain http).
# Leave false for on-prem LAN deployments; set true for the AWS cloud trial
# deployment where Caddy terminates TLS.
COOKIE_SECURE=false

# WebAuthn ceremony state backend (memory | redis).
# - memory: in-process dictionaries (pilot-friendly, single-process only).
# - redis: shared backend for multi-worker or multi-instance deployments.
WEBAUTHN_STATE_BACKEND=memory

# Enforce single-process backend when using in-memory WebAuthn state.
# If true and worker count env indicates >1 workers, backend startup fails fast.
WEBAUTHN_REQUIRE_SINGLE_PROCESS=true

# Inference profile (auto | low_vram | server).
# - auto: keep explicit per-model preload flags as the primary behavior.
# - low_vram: prefer staged load/unload policy for weaker GPUs.
# - server: prefer resident models for high-end inference servers.
INFERENCE_PROFILE=auto

# Pipeline unload policy (stage | never).
# - stage: unload heavy models after each stage to free VRAM.
# - never: keep models resident between stages/jobs for max throughput.
# Recommended:
# - low-VRAM workstation: stage
# - server (2x5080 class): never
PIPELINE_UNLOAD_POLICY=stage

# Max number of studies processed concurrently by backend queue workers.
# Increase carefully; higher values increase VRAM pressure.
# Recommended:
# - low-VRAM workstation: 1
# - server (2x5080 class): 2
PIPELINE_MAX_ACTIVE_STUDIES=1

# Scheduler queue scan interval in milliseconds.
# Lower values react faster but can increase CPU wake-ups.
PIPELINE_POLL_INTERVAL_MS=500

# Global view confidence gate for queue prefilter routing.
# Instances with classifier confidence below this threshold are skipped.
# Recommended start value: 0.75
PIPELINE_VIEW_CONFIDENCE_MIN=0.75

# Draft progress snapshot commit throttle for the dynamic measurement stage.
# 1.0 keeps UI polling fresh while avoiding dozens of commit round-trips during
# 9-weight measurement passes. Set 0 to restore commit-on-every-update behavior.
PIPELINE_PROGRESS_COMMIT_INTERVAL_S=1.0

# Model preload toggles (true | false).
# Explicit preload values override profile-derived defaults.
# Set false on low-VRAM systems if startup/preload causes memory pressure.
PRIMARY_ANALYSIS_PRELOAD=true
PRIMARY_ANALYSIS_WARMUP=false
SECONDARY_ANALYSIS_PRELOAD=true
SECONDARY_ANALYSIS_WARMUP=false
# Start or upgrade the background EchoPrime warm-up after a hospital user signs in.
# Lifecycle: startup may load the model without warming it; the first hospital
# login requests warm-up of that same loaded model, so the first study avoids
# EchoPrime model construction and CUDA-kernel initialization latency.
# Login is never blocked. Set false on low-VRAM machines that should preserve GPU
# memory while idle instead of optimizing the first-study latency.
SECONDARY_ANALYSIS_WARMUP_ON_LOGIN=true
MOTION_SEGMENTATION_PRELOAD=true
MOTION_SEGMENTATION_WARMUP=false
STUDY_MEASUREMENTS_PRELOAD=true
STUDY_MEASUREMENTS_WARMUP=false

# Batch sizes (integers). The backend automatically halves a CUDA batch after
# an out-of-memory error and retries the same work, so start at the recommended
# values below and increase one setting at a time while watching GPU memory.
#
# Tuning guide:
# - 4-8 GB VRAM: use 16 for STUDY_MEASUREMENTS_BATCH.
# - 8-12 GB VRAM: 32 is the recommended starting point.
# - 16+ GB VRAM: benchmark 48, then 64; keep the fastest stable value.
# - Run the same representative study after each change and retain only values
#   that complete without sustained memory pressure or a slower total runtime.
PRIMARY_ANALYSIS_BATCH=8
MOTION_SEGMENTATION_BATCH=16
STUDY_MEASUREMENTS_BATCH=32

# --- Mixed precision / accelerator tuning (GPU only; CPU path unchanged) ---
# See docs/ai-pipelines/INFERENCE_OPTIMIZATION.md. Validate FP16 parity with
# backend/scripts/benchmarks/validate_parity.py before enabling in production.
INFERENCE_AMP_ENABLED=true
INFERENCE_AMP_DTYPE=float16
INFERENCE_CHANNELS_LAST=true
INFERENCE_CUDNN_BENCHMARK=true
INFERENCE_ALLOW_TF32=true
# View classification is a discrete decision; keep its AMP off until validated.
SECONDARY_ANALYSIS_AMP_ENABLED=false

# torch.compile for fixed-shape inference CNNs (Part 4). Opt-in: needs a working
# Inductor/Triton backend (Linux CUDA); no-op elsewhere. Enable the *_WARMUP
# flags so the one-time compile cost lands before the first patient study.
INFERENCE_TORCH_COMPILE=false
INFERENCE_TORCH_COMPILE_MODE=reduce-overhead

# CPU/GPU overlap (Part 3): prefetch next-chunk decode and run per-frame
# postprocess on worker threads while the GPU runs. Outputs unchanged.
INFERENCE_CPU_GPU_OVERLAP=true
INFERENCE_POSTPROCESS_WORKERS=0

# --- Temporal keypoint sampling for the 2D linear lane (Part 4) ---
# Recommended performance profile: infer every second frame and interpolate
# the remaining frames. This substantially reduces 2D measurement runtime.
# The runtime self-check below samples skipped frames and automatically falls
# back to full-frame inference when interpolation exceeds the error limit.
#
# Validation requirement: compare output with stride 1 on representative
# clinical studies before using a higher stride in a production deployment.
# Do not increase beyond 2 without a dedicated parity report.
LINEAR_TEMPORAL_STRIDE=2
LINEAR_TEMPORAL_INTERPOLATION=true
LINEAR_TEMPORAL_SELF_CHECK=true
LINEAR_TEMPORAL_SELF_CHECK_SAMPLES=3
LINEAR_TEMPORAL_MAX_POINT_ERROR_PX=2.0
LINEAR_TEMPORAL_MAX_LENGTH_ERROR_CM=0.1

# Output FPS for generated measurement videos.
MEASUREMENTS_OUTPUT_FPS=30

# Max DICOM files a doctor can upload for one study.
# Lower on constrained machines to reject very large studies before pipeline work starts.
DICOM_UPLOAD_MAX_FILES=50

# Secondary-analysis EchoPrime safety cap.
# Counts only instances entering EchoPrime; above this value the stage fails cleanly.
SECONDARY_ANALYSIS_MAX_INSTANCES=100

# Secondary-analysis chunk sizes.
# Lower values reduce RAM/VRAM use at the cost of speed.
# ENCODER_BATCH drives the MViT video encoder: 4 is a low-VRAM default and
# underfeeds RTX-class GPUs; 16 is the recommended value on >=16 GB cards.
SECONDARY_ANALYSIS_CLASSIFY_CHUNK_SIZE=8
SECONDARY_ANALYSIS_METRICS_CHUNK_SIZE=8
SECONDARY_ANALYSIS_ENCODER_BATCH=4

# Preferred devices (auto | cpu | cuda:<index>).
# Examples: auto, cpu, cuda:0, cuda:1
PRIMARY_ANALYSIS_DEVICE=auto
SECONDARY_ANALYSIS_DEVICE=auto
MOTION_SEGMENTATION_DEVICE=auto
STUDY_MEASUREMENTS_DEVICE=auto
REPORTING_RESERVED_DEVICE=

# LLM toggle + backend client contract.
ENABLE_LLM=true
LLM_BASE_URL=http://localhost:8012/v1
REPORTING_MODEL_ID=local-reporting-model
LLM_SERVER_MAX_LEN=16384

# Server-side WSL bootstrap/runtime values used by the LLM wrapper scripts.
LLM_WSL_DISTRO=Ubuntu
LLM_VENV_PATH=~/vllm
LLM_GPU_INDEX=1
HF_HOME=

# Server-side licensing.
# Packaged server builds embed enforcement + verification key at build time.
# These values remain useful for local dev and as the build-time fallback source.
LICENSE_ENFORCEMENT=false
LICENSE_STORAGE_DIR=
LICENSE_PUBLIC_KEY_B64=

# Hidden packaged-server vendor access.
# Build-time only for packaged server release generation; omitted from shipped runtime env.
VENDOR_ACCESS_ENABLED=false
VENDOR_ACCESS_USERNAME=
VENDOR_ACCESS_DISPLAY_NAME=
VENDOR_ACCESS_PASSWORD_HASH=
