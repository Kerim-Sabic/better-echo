# Authoritative template for the cloud runtime .env.
#
# This documents the COMPLETE set of keys that docker-compose.cloud.yml reads.
# The real .env is NOT committed and is NOT written by hand — bootstrap.sh
# generates it on the EC2 at first boot. This file and bootstrap.sh's heredoc
# must stay in lockstep: every key here must be rendered by bootstrap.sh, and
# vice versa. If you add a runtime setting, add it in three places only:
#   1. here (documented default),
#   2. bootstrap.sh's heredoc (rendered value),
#   3. docker-compose.cloud.yml's `environment:` as KEY: "${KEY}".
#
# Layering (see deploy/cloud/README.md):
#   Terraform tfvars ──► /etc/horalix/bootstrap.env ──► this .env ──► backend
#   - Per-tenant values come from Terraform (vary per hospital).
#   - Fixed cloud defaults are identical for every tenant.
#
# NOT listed here (intentionally — they are not .env config):
#   - DATABASE_URL / ORTHANC_URL / LLM_BASE_URL: internal compose-network
#     topology, hardcoded in docker-compose.cloud.yml.
#   - BACKEND_HOST / BACKEND_PORT / PYTHONUNBUFFERED: image-intrinsic, set in
#     backend.Dockerfile.

# ===========================================================================
# Per-tenant (Terraform writes these into /etc/horalix/bootstrap.env)
# ===========================================================================
# Hostname this EC2 answers on. Must resolve via Route53 to the instance IP
# before `docker compose up`, or Let's Encrypt fails.
DOMAIN=acme.echo.horalix.com
# Operator email for Let's Encrypt expiry notices.
ACME_EMAIL=ops@horalix.com
# Generate per-tenant: `openssl rand -base64 32`
POSTGRES_PASSWORD=replace-me-per-tenant
# Generate per-tenant: `openssl rand -hex 32`
SECRET_KEY=replace-me-per-tenant
# Base64-encoded Ed25519 public key matching the operator's signing key.
LICENSE_PUBLIC_KEY_B64=
REPORTING_MODEL_ID=local-reporting-model
TOKEN_EXPIRE_HOURS=12
# true only on GPU tenants; bootstrap.sh derives this from Terraform enable_gpu.
ENABLE_LLM=false

# ===========================================================================
# Derived from DOMAIN (bootstrap.sh computes this)
# ===========================================================================
CORS_ORIGIN=["https://acme.echo.horalix.com"]

# ===========================================================================
# Fixed cloud defaults (identical for every tenant)
# ===========================================================================
BACKEND_IMAGE_TAG=dev
LLM_IMAGE_TAG=dev
VIEWER_IMAGE_TAG=cloud
POSTGRES_DB=horalix
POSTGRES_USER=horalix
ORTHANC_USER=orthanc
ORTHANC_PASS=orthanc
# Backend is reached over HTTPS behind Caddy, so cookies must be Secure.
COOKIE_SECURE=true
LICENSE_ENFORCEMENT=true
# Must match the EBS bind-mount path in docker-compose.cloud.yml.
LICENSE_STORAGE_DIR=/var/lib/horalix/licensing

# ===========================================================================
# LLM (vLLM) tuning — only consumed by the gpu-profile llm service
# ===========================================================================
LLM_SERVER_MAX_LEN=16384
# Lowered from the on-prem default (0.90) because backend and LLM share one GPU
# on g5.xlarge. Tune up if you size up the instance.
LLM_GPU_MEMORY_UTILIZATION=0.60
LLM_MAX_NUM_SEQS=2
